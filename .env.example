# =============================================================================
# SCSI — Template de variáveis de ambiente (seção 42 do PRD.md)
# Copie para `.env` e preencha com valores reais. NÃO versione o `.env`.
# =============================================================================

# --- Django core ---
DEBUG=False
SECRET_KEY=troque-esta-chave-em-producao
# Listas separadas por vírgula (lidas via django-environ). Use ponto inicial
# (.scsi.digital) para casar qualquer subdomínio.
ALLOWED_HOSTS=scsi.digital,.scsi.digital,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://scsi.digital,https://*.scsi.digital,http://localhost:8000,http://127.0.0.1:8000

# --- Localização ---
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# --- Banco de dados (PostgreSQL em prod/Docker; em dev local pode-se omitir
#     DATABASE_URL para cair no SQLite padrão) ---
DATABASE_URL=postgres://scsi:senha@db:5432/scsi
POSTGRES_DB=scsi
POSTGRES_USER=scsi
POSTGRES_PASSWORD=troque-esta-senha

# --- Celery / RabbitMQ / Redis (Sprint 2/3) ---
CELERY_BROKER_URL=amqp://scsi:senha@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0
RABBITMQ_DEFAULT_USER=scsi
RABBITMQ_DEFAULT_PASS=troque-esta-senha
REDIS_URL=redis://redis:6379/1

# --- IA / OpenAI (Sprint 21/22) ---
OPENAI_API_KEY=sk-troque-esta-chave
OPENAI_MODEL=gpt-5.5-mini

# --- E-mail / SMTP (Sprint 4) ---
EMAIL_HOST=smtp.provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@scsi.digital
EMAIL_HOST_PASSWORD=troque-esta-senha
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=SCSI <no-reply@scsi.digital>

# --- Arquivos ---
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# --- Produção / Deploy (Sprint 27) ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
# E-mail usado pelo Let's Encrypt (Traefik) ao emitir o certificado.
ACME_EMAIL=admin@scsi.digital
# Domínio do projeto. Controla TUDO no Traefik via interpolação no docker-stack.yml:
#   - certificado TLS wildcard:  ${DOMAIN} e *.${DOMAIN}
#   - host do app:               Host(`${DOMAIN}`)
#   - host do dashboard:         Host(`traefik.${DOMAIN}`)
# Troque para o seu domínio. O docker stack deploy lê esta variável do ambiente
# (o deploy.sh / setup_deploy.sh carregam o .env antes de subir a stack).
DOMAIN=scsi.digital

# Basic Auth do dashboard do Traefik no formato "usuario:hash".
# Gere o hash com (instale antes: sudo apt install apache2-utils):
#   htpasswd -nbB admin 'SUA_SENHA'
# Cole a saída AQUI com UM cifrão ($) — NÃO duplique. O docker-stack.yml injeta
# via ${TRAEFIK_DASHBOARD_AUTH}, então não precisa de '$$'. Se ficar vazio, o
# stack usa um hash padrão de fallback. (O setup_deploy.sh preenche isto sozinho.)
TRAEFIK_DASHBOARD_AUTH=
